#include 'tlpp-core.th'
#include 'tlpp-rest.th'

#include "protheus.ch"
#include "fwmvcdef.ch"

//define o namespace que a tela em mvc ficara agrupada. [necessÃrio para MVC em TLPP]
namespace MvcFunctionCompany

//expoem o cadastro mvc em uma API
PUBLISH USER MODEL REST NAME CadFncComp SOURCE "MvcFunctionCompany.FuncComp"

/*/{Protheus.doc} FncComp
Classe para gerenciamento da tela MVC Cadastro de FunÓ¾es x Empresas herdando os mÕtodos da classe FWModelEvent
@type class
@author eduardo.brust
@since 1/20/2026
/*/
Class FncComp From FWModelEvent

	//atributos
	public data  oTempTable as object
	public data  oBrowseTable as object
	public data  aRotina  as array
	public data  cAliasTmp as character
	public data  cTitulo as character
	public data  aCampos as array
	public data  aColunas as array
	public data  aPesquisa as array

	//mÕtodos
	protected Method New() CONSTRUCTOR //metodo construtor da classe
	protected method finish() //limpar  os objetos e arrays da memµria antes de eliminar a instancia da classe
	protected Method TempTable()  //criaÓÐo da tabela temporaria do MVC
	protected Method BrowseTable()  //criaÓÐo da tela com dados da tabela temporaria
	protected Method ExistPK(cFunction as character, cCompany as character) as logical
	public Method BeforeTTS(oModel as object)  //antes da transaÓÐo do commit
	public Method InTTS(oModel as object)    //durante a transaÓÐo do commit
	public Method AfterTTS(oModel as object)  //depois da transaÓÐo do commit
	public Method ModelPosVld(oModel as object, cModelId as character) as logical // MÕtodo para validaÓÐo total do modelo
EndClass


/*/{Protheus.doc} FncComp::New
è o **mÕtodo construtor** da classe. Ele Õ responsÃvel por inicializar os atributos essenciais, como o tÚtulo da rotina, 
os arrays de colunas e pesquisa, e definir o nome do Alias temporÃrio (`temp_FncComp`).
@type method
@author eduardo.brust
@since 1/21/2026
@return object, retorna a instancia do objeto
/*/
Method New() CLASS  FncComp

	// inicializaÓÐo dos atributos
	::oTempTable  := nil
	::oBrowseTable := nil
	::aRotina     := {}
	::cAliasTmp   := "temp_FncComp"
	::cTitulo     := "MVC - TLPP - USANDO CLASSE E MèTODOS BeforeTTS/InTTS/AfterTTS - Tela de amarraÓÐo Rotinas x Empresas"
	::aCampos     := {}
	::aColunas    := {}
	::aPesquisa   := {}

Return self


/*/{Protheus.doc} FncComp::finish
MÕtodo destinado Á **limpeza de memµria**. Ele desativa e destrµi o objeto de Browse, deleta fisicamente a tabela temporÃria do banco de dados (Oracle/SQL) 
e limpa todos os arrays utilizados para evitar vazamento de memµria.
@type method
@author eduardo.brust
@since 1/22/2026 
/*/
Method finish() CLASS FncComp

	//limpo o componente de tela
	If ::oBrowseTable <> Nil
		::oBrowseTable:DeActivate()
		::oBrowseTable:Destroy()
		::oBrowseTable := Nil
	EndIf

	// Limpo a tabela fÚsica do banco de dados (Drop Table)
	If ::oTempTable <> Nil
		::oTempTable:Delete()
		::oTempTable := Nil
	EndIf

	// Limpeza de arrays
	aSize(::aRotina, 0)
	::aRotina := Nil

	aSize(::aCampos, 0)
	::aCampos := Nil

	aSize(::aColunas, 0)
	::aColunas := Nil

	aSize(::aPesquisa, 0)
	::aPesquisa := Nil

Return


/*/{Protheus.doc} FncComp::TempTable
Este mÕtodo realiza a **criaÓÐo da estrutura da tabela temporÃria** utilizando a classe `FWTemporaryTable`. AlÕm de criar a tabela no banco, ele executa um comando `INSERT INTO ... 
SELECT` para popular a temporÃria com dados da tabela real `FUNCTION_COMPANY` em conjunto com a `SYS_COMPANY`.
@type method
@author eduardo.brust
@since 1/20/2026
/*/
Method TempTable() CLASS FncComp
	Local cQryUpd       as character
	Local cTRealName    as character
	Local nStatus       as numeric

	cQryUpd     := ""
	cTRealName  := ""

	//Campos da temporÃria
	aAdd(::aCampos, {"TCFUNCTION", "C", 050, 0})
	aAdd(::aCampos, {"TCOMPANY",   "C", 006, 0})
	aAdd(::aCampos, {"TABBREV", "C", 010, 0})
	aAdd(::aCampos, {"TM0NOMECOM", "C", 060, 0})
	aAdd(::aCampos, {"TM0_CGC", "C", 014, 0})
	aAdd(::aCampos, {"TACTIVE", "C", 001, 0})

	//Cria a temporÃria
	::oTempTable := FWTemporaryTable():New(::cAliasTmp)
	::oTempTable:SetFields(::aCampos)
	::oTempTable:AddIndex("1", {"TCFUNCTION"} )
	::oTempTable:AddIndex("2", {"TCOMPANY"} )
	::oTempTable:Create()
	cTRealName := ::oTempTable:GetRealName()
	::cTitulo :=  ::cTitulo  + "Tabela temporÃria : " + cTRealName

	//Agora vamos inserir os dados na temporÃria conforme os que existem no banco de dados
	cQryUpd := ""
	cQryUpd += " INSERT INTO " + cTRealName + CRLF
	cQryUpd += " (TCFUNCTION, TCOMPANY, TABBREV, TM0NOMECOM,TM0_CGC,TACTIVE) " + CRLF
	cQryUpd += " SELECT CFUNCTION, COMPANY, ABBREVIATION, M0_NOMECOM,M0_CGC,ACTIVE " + CRLF
	cQryUpd += " FROM FUNCTION_COMPANY " + CRLF
	cQryUpd += " INNER JOIN SYS_COMPANY " + CRLF
	cQryUpd += " ON D_E_L_E_T_ = ' ' " + CRLF
	cQryUpd += " AND M0_CODIGO = '00' " + CRLF
	cQryUpd += " AND SUBSTR(M0_CODFIL,1,6) = COMPANY " + CRLF
	cQryUpd += " ORDER BY 2 " + CRLF

	nStatus := TCSQLExec(cQryUpd)

Return

/*/{Protheus.doc} FncComp::BrowseTable
ResponsÃvel pela **configuraÓÐo visual do Browse**. Ele define quais colunas da tabela temporÃria serÐo exibidas para o usuÃrio e 
configura os Úndices de pesquisa (busca por funÓÐo e empresa) que estarÐo disponÚveis na lupa da interface.
@type method 
@author eduardo.brust
@since 1/20/2026
/*/
Method BrowseTable() CLASS FncComp

	//Definindo as colunas que serÐo usadas no browse
	aAdd(::aColunas, {"CFUNCTION",    "TCFUNCTION", "C", 050, 0, ""})
	aAdd(::aColunas, {"COMPANY",      "TCOMPANY",   "C", 006, 0, ""})
	aAdd(::aColunas, {"ABBREVIATION",   "TABBREV", "C", 010, 0, ""})
	aAdd(::aColunas, {"M0_NOMECOM",   "TM0NOMECOM", "C", 060, 0, ""})
	aAdd(::aColunas, {"M0_CGC",   "TM0_CGC", "C", 014, 0, ""})
	aAdd(::aColunas, {"ACTIVE",   "TACTIVE", "C", 001, 0, ""})

	//Adiciona os indices para pesquisar
    /*
        [n,1] TÚtulo da pesquisa
        [n,2,n,1] LookUp
        [n,2,n,2] Tipo de dados
        [n,2,n,3] Tamanho
        [n,2,n,4] Decimal
        [n,2,n,5] TÚtulo do campo
        [n,2,n,6] MÃscara
        [n,2,n,7] Nome FÚsico do campo - Opcional - Õ ajustado no programa
        [n,3] Ordem da pesquisa
        [n,4] Exibe na pesquisa
    */
	aAdd(::aPesquisa, {"CFUNCTION", {{"", "C", 050, 0, "CFUNCTION", "@!", "TCFUNCTION",1,.t.}} } )
	aAdd(::aPesquisa, {"COMPANY", {{"", "C", 006, 0, "COMPANY", "@!", "TCOMPANY",2,.t.}} } )

Return

/*/{Protheus.doc} as
Consulta se a combinaÓÐo de Rotina e Empresa jÃ existe na tabela FUNCTION_COMPANY.
@type function
@author eduardo.brust
@since 1/23/2026
@return logical, retorna .t. ou .f. caso ache o registro ou nao na tabela
/*/
Method ExistPK(cFunction as character, cCompany as character) as logical CLASS FncComp
	Local lFound    as logical
	Local cSql      as character
	Local cAliasQry as character

	default	cFunction := " "
	default	cCompany := " "

	lFound := .F.
	cSql	:= ""
	cAliasQry  := GetNextAlias()

	// Monta a query de consulta na tabela fÚsica real
	cSql := " SELECT 1 AS EXISTE "
	cSql += " FROM FUNCTION_COMPANY "
	cSql += " WHERE CFUNCTION = '" + AllTrim(cFunction) + "' "
	cSql += " AND COMPANY = '" + AllTrim(cCompany) + "' "

	// Executa a consulta no SGBD de forma otimizada
	MPSysOpenQuery(cSql, cAliasQry)

	// Se o cursor nÐo estiver no fim, significa que encontrou o registro
	If !(cAliasQry)->(Eof())
		lFound := .T.
	EndIf

	// Fecha a Ãrea da consulta para liberar memµria
	(cAliasQry)->(dbCloseArea())

Return lFound

/*/{Protheus.doc} FncComp::ModelPosVld
MÕtodo de pµs-validaÓÐo total do modelo (TudoOk).
@type method
@author eduardo.brust
@since 1/23/2026
@return logical, retorna .t. ou .f. dependendo da validaÓÐo
/*/
Method ModelPosVld(oModel as object, cModelId as character) as logical CLASS FncComp
	Local lRet as logical
	Local cFunction as character
	Local cCompany as character
	Local nOperacao as numeric

	nOperacao := oModel:GetOperation()
	cFunction := oModel:GetValue("FORMTMP", "TCFUNCTION")
	cCompany := oModel:GetValue("FORMTMP", "TCOMPANY")
	lRet := .T.

	//VALIDACAO DE PREENCHIMENTO DE CAMPOS
	If Empty(cFunction)
		// No Model, mensagens de erro devem usar Help() ou SetErrorMessage
		oModel:SetErrorMessage("FORMTMP", "TCFUNCTION", "FORMTMP", "TCFUNCTION", "VAL01", "Rotina nÐo informada", "Informe o cµdigo da rotina")
		lRet := .F.
	ELSEIF Empty(cCompany)
		oModel:SetErrorMessage("FORMTMP", "TCOMPANY", "FORMTMP", "TCOMPANY", "VAL02", "Empresa nÐo informada", "Informe o cµdigo da empresa")
		lRet := .F.
	ELSEIF Empty(oModel:GetValue("FORMTMP", "TACTIVE"))
		oModel:SetErrorMessage("FORMTMP", "TACTIVE", "FORMTMP", "TACTIVE", "VAL03", "Ativo/Inativo nÐo informado", "Informe a situaÓÐo do cadastro")
		lRet := .F.
	EndIf

	IF lRet .AND. nOperacao = 3 // SOMENTE NA INCLUSAO
		IF ::ExistPK(cFunction,cCompany)
			oModel:SetErrorMessage(;
				"FORMTMP",;             // [5] ID do submodelo em validaÓÐo [2]
			"TCFUNCTION",;          // [6] ID do campo que receberÃ o foco (cursor) [7]
			"FORMTMP",;             // [8] ID do submodelo onde ocorreu o erro
			"TCFUNCTION",;          // [9] ID do campo de erro
			"PKEXIST",;             // [10] ID identificador deste erro especÚfico [7]
			"O registro com a Rotina '" + AllTrim(cFunction) + "' e Empresa '" + AllTrim(cCompany) + "' jÃ estÃ cadastrado.",; // [11] Mensagem de erro [7]
			"Verifique os dados informados ou utilize a opÓÐo 'Alterar' se desejar modificar o registro existente."; // [12] Mensagem de soluÓÐo [7]
			)
			lRet := .F.
		ENDIF
	ENDIF

Return lRet

/*/{Protheus.doc} FncComp::BeforeTTS
Evento disparado **antes do inÚcio da transaÓÐo** de banco de dados. 
è utilizado para validaÓ¾es finais que devem ocorrer antes que o Protheus abra o processo de gravaÓÐo (commit).
@type method
@author eduardo.brust
@since 1/22/2026
/*/
Method BeforeTTS(oModel as object) CLASS FncComp
	Local nOperacao as numeric // ObtÕm a operaÓÐo (4 = AlteraÓÐo) [1, 2]

	nOperacao := oModel:GetOperation()

	// O BeforeTTS Õ o local ideal para validaÓ¾es finais ou preparo de dados externos
	// que devem ocorrer ANTES de a transaÓÐo ser aberta no banco [3-5].
	If nOperacao == 4
		// Exemplo: Vocõ poderia verificar aqui se o registro ainda existe no Oracle
		// ou se hÃ algum bloqueio antes de permitir que o Protheus inicie o commit. [4]
	EndIf
Return

/*/{Protheus.doc} FncComp::InTTS
Evento acionado **apµs a gravaÓÐo na tabela temporÃria**, mas ainda dentro da transaÓÐo ativa. 
è o local ideal para atualizaÓ¾es em tabelas relacionadas que precisariam de um *rollback* automÃtico caso ocorra algum erro crÚtico.
@type method
@author eduardo.brust
@since 1/22/2026
/*/
Method InTTS(oModel as object) CLASS FncComp
	Local nOperacao as numeric      // ObtÕm a operaÓÐo
	Local oModelTmp as object       // Acessa o submodelo definido no seu ModelDef
	Local cQry      as character
	Local nStatus as numeric
	Local cEmpresa as character
	Local cFuncao  as character

	nOperacao := oModel:GetOperation() // ObtÕm a operaÓÐo
	oModelTmp := oModel:GetModel("FORMTMP") // Acessa o submodelo definido no seu ModelDef
	cQry      := ""
	cEmpresa := AllTrim(oModelTmp:GetValue("TCOMPANY"))
	cFuncao  := AllTrim(oModelTmp:GetValue("TCFUNCTION"))

	// 1. Trata a INCLUSûO (Somente campos fÚsicos da FUNCTION_COMPANY)
	If nOperacao == 3

		// ATUALIZA A TEMPORêRIA COM O DADO DO JOIN
		// Como o registro acabou de ser inserido, o Alias temporÃrio estÃ posicionado.
		// busco o nome da empresa e cgc para preencher o campo visual.
		cQry := " UPDATE " + ::oTempTable:GetRealName() + " SET " + CRLF
		cQry += " TM0NOMECOM = (SELECT M0_NOMECOM FROM SYS_COMPANY WHERE M0_CODIGO = '00' AND SUBSTR(M0_CODFIL,1,6) = '" + cEmpresa + "'), " + CRLF
		cQry += " TM0_CGC    = (SELECT M0_CGC     FROM SYS_COMPANY WHERE M0_CODIGO = '00' AND SUBSTR(M0_CODFIL,1,6) = '" + cEmpresa + "') " + CRLF
		cQry += " WHERE TCFUNCTION = '" + cFuncao + "' " + CRLF
		cQry += " AND TCOMPANY     = '" + cEmpresa + "' "

		TCSQLExec(cQry) // Atualiza a temporÃria localmente

		//atualiza a tabela fÚsica do banco
		cQry := " INSERT INTO FUNCTION_COMPANY " + CRLF
		cQry += " (CFUNCTION, COMPANY, ABBREVIATION, ACTIVE) " + CRLF
		cQry += " VALUES " + CRLF
		cQry += " ('" + cFuncao + "', " + CRLF
		cQry += "  '" + cEmpresa   + "', " + CRLF
		cQry += "  '" + AllTrim(oModelTmp:GetValue("TABBREV"))    + "', " + CRLF
		cQry += "  '" + AllTrim(oModelTmp:GetValue("TACTIVE"))    + "') " + CRLF

		// Trata a ALTERAúûO (Atualiza campos editÃveis usando a PK no WHERE)
	ElseIf nOperacao == 4
		cQry := " UPDATE FUNCTION_COMPANY SET " + CRLF
		cQry += " ACTIVE       = '" + AllTrim(oModelTmp:GetValue("TACTIVE")) + "' " + CRLF
		cQry += " WHERE CFUNCTION = '" + cFuncao + "' " + CRLF
		cQry += " AND COMPANY     = '" + cEmpresa   + "' " + CRLF

		// 3. Trata a EXCLUSûO (Opcional, para manter a integridade total)
	ElseIf nOperacao == 5
		cQry := " DELETE FROM FUNCTION_COMPANY " + CRLF
		cQry += " WHERE CFUNCTION = '" + cFuncao + "' " + CRLF
		cQry += " AND COMPANY     = '" + cEmpresa   + "' " + CRLF
	EndIf

	// Executa a query se houver uma operaÓÐo vÃlida
	If !Empty(cQry)
		nStatus := TCSQLExec(cQry) // Persiste as mudanÓas diretamente no banco de dados real
	EndIf
Return


/*/{Protheus.doc} FncComp::AfterTTS
MÕtodo que Õ chamado apos a transacao
@type method
@author eduardo.brust
@since 1/22/2026
/*/

Method AfterTTS(oModel as object) CLASS FncComp
