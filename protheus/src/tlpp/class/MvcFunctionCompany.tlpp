Return


/*/{Protheus.doc} FuncComp
è a **funÓÐo principal (ponto de entrada)** da rotina. Ela coordena o fluxo operacional: instancia a classe `FncComp`, chama a criaÓÐo da tabela temporÃria e do browse, 
ativa a interface MVC e, ao final, garante a limpeza dos objetos atravÕs do mÕtodo `finish()`.
@type function
@author eduardo.brust
@since 1/22/2026

/*/
User function FuncComp()
	local aArea as array

	Private oFncComp as object

	aArea := getArea()

	//RETIRAR DEPOIS DE TESTAR

	//RpcClearEnv()
	//RpcSetType(3)
	//lRet := RpcSetEnv( "00", "010101", , ,,ProcName(), )

	oFncComp := MvcFunctionCompany.FncComp():New()  //instancio o objeto da classe

	//Definicao do menu
	oFncComp:aRotina := MvcFunctionCompany.U_MenuDef()

	//chamo o mÕtodo para criaÓÐo da tabela temporÃria
	oFncComp:TempTable()

	//chamo o mÕtodo para popular a tela com os dados ta tabela
	oFncComp:BrowseTable()

	//Criando o browse da temporÃria
	MvcFunctionCompany.U_BrowseDef()

	//chamo metµdo para limpeza dos objetos da clase
	oFncComp:finish()

	//elimino a instancia da classe em memµria
	FreeObj(oFncComp)
	oFncComp := nil

	//restauro a Ãrea do protheus em memµria
	FWRestArea(aArea)

return nil

/*/BrowseDef
	Retorna o browse da rotina
return oBrowse Objeto do tipo FWMBrowse(FWBrowse)
	author Eduardo Brust
	since 16/01/2026
/*/

/*/{Protheus.doc} BrowseDef
FunÓÐo que define o objeto **`FWMBrowse`**. Ela configura o Alias temporÃrio, associa as colunas definidas no mÕtodo `BrowseTable` e ativa o componente visual de navegaÓÐo na tela.
@type function
@author eduardo.brust
@since 1/22/2026
/*/
User function BrowseDef() as object

	//Criando o browse da temporÃria
	oFncComp:oBrowseTable := FWMBrowse():New()
	oFncComp:oBrowseTable:SetAlias(oFncComp:cAliasTmp)

	oFncComp:oBrowseTable:AddLegend( "TACTIVE=='Y'", "GREEN", "Ativo" )
	oFncComp:oBrowseTable:AddLegend( "TACTIVE=='N'", "RED",   "Inativo" )

	oFncComp:oBrowseTable:SetTemporary(.T.)
	oFncComp:oBrowseTable:SetFields(oFncComp:aColunas)

	oFncComp:oBrowseTable:SetUseCaseFilter(.T.)

	oFncComp:oBrowseTable:DisableDetails()
	oFncComp:oBrowseTable:SetDescription(oFncComp:cTitulo)
	oFncComp:oBrowseTable:SetSeek(.T., oFncComp:aPesquisa)
	oFncComp:oBrowseTable:SetMenuDef("MvcFunctionCompany.FuncComp")
	oFncComp:oBrowseTable:Activate()
return


/*/{Protheus.doc} ModelDef
Define o **Modelo de Dados (Model)** do MVC. Nesta funÓÐo, sÐo descritas as estruturas de campos, as regras de negµcio (como validaÓ¾es de nºmeros em campos de empresa), 
a chave primÃria do modelo e a instalaÓÐo de eventos da classe para monitorar a gravaÓÐo. 
@type function
@author eduardo.brust
@since 1/21/2026
@return object, retorna o objeto do model
/*/
User function ModelDef() as object
	Local oModel := Nil
	Local oStTMP := FWFormModelStruct():New()

	//Na estrutura, define os campos e a temporÃria
	oStTMP:AddTable(oFncComp:cAliasTmp, {'TCFUNCTION', 'TCOMPANY', 'TABBREV', 'TM0NOMECOM','TM0_CGC','TACTIVE'}, "Temporaria")

	//Adiciona os campos da estrutura
	oStTmp:AddField(;
		"Rotina",;                                                                              // [01]  C   Titulo do campo
	"Rotina",;                                                                                  // [02]  C   ToolTip do campo
	"TCFUNCTION",;                                                                              // [03]  C   Id do Field
	"C",;                                                                                       // [04]  C   Tipo do campo
	050,;                                                                                       // [05]  N   Tamanho do campo
	0,;                                                                                         // [06]  N   Decimal do campo
	Nil,;                                                                                       // [07]  B   Code-block de validaÓÐo do campo
	FwBuildFeature(STRUCT_FEATURE_WHEN, "INCLUI"),;                                             // [08]  B   Code-block de validaÓÐo When do campo
	{},;                                                                                        // [09]  A   Lista de valores permitido do campo
	.T.,;                                                                                       // [10]  L   Indica se o campo tem preenchimento obrigatµrio
	FwBuildFeature( STRUCT_FEATURE_INIPAD, "Iif(!INCLUI,"+oFncComp:cAliasTmp+"->TCFUNCTION,'')" ),;      // [11]  B   Code-block de inicializacao do campo
	.T.,;                                                                                       // [12]  L   Indica se trata-se de um campo chave
	.F.,;                                                                                       // [13]  L   Indica se o campo pode receber valor em uma operaÓÐo de update.
	.F.)                                                                                        // [14]  L   Indica se o campo Õ virtual

	oStTmp:AddField(;
		"Empresa",;                                         // [1] Titulo
	"Empresa",;                                         // [2] ToolTip
	"TCOMPANY",;                                        // [3] ID
	"C",;                                               // [4] Tipo
	006,;                                               // [5] Tamanho
	0,;                                                 // [6] Decimal
	FwBuildFeature(STRUCT_FEATURE_VALID, "IsNumeric(AllTrim(M->TCOMPANY)) .And. Len(AllTrim(M->TCOMPANY)) == 6"),;  // [07]  B   Code-block de validaÓÐo do campo
	FwBuildFeature(STRUCT_FEATURE_WHEN, "INCLUI"),;     // [8] When
	{},;                                                // [9] Values
	.T.,;                                               // [10] Obrigatµrio
	FwBuildFeature(STRUCT_FEATURE_INIPAD, "Iif(!INCLUI, " + oFncComp:cAliasTmp + "->TCOMPANY, '')" ),; // [11]  B   Code-block de inicializacao do campo
	.F.,;                                               // [12]  L   Indica se trata-se de um campo chave
	.F.,;                                               // [13]  L   Indica se o campo pode receber valor em uma operaÓÐo de update.
	.F.)                                                // [14]  L   Indica se o campo Õ virtual

	oStTmp:AddField(;
		"Sigla",;                                                                                   // [01]  C   Titulo do campo
	"Sigla",;                                                                                   // [02]  C   ToolTip do campo
	"TABBREV",;                                                                                 // [03]  C   Id do Field
	"C",;                                                                                       // [04]  C   Tipo do campo
	010,;                                                                                        // [05]  N   Tamanho do campo
	0,;                                                                                         // [06]  N   Decimal do campo
	FwBuildFeature(STRUCT_FEATURE_VALID, "!IsNumeric(AllTrim(M->TABBREV)) .And. Len(AllTrim(M->TABBREV)) <= 10"),;  // [07]  B   Code-block de validaÓÐo do campo
	Nil,;                                                                                       // [08]  B   Code-block de validaÓÐo When do campo
	{},;                                                                                        // [09]  A   Lista de valores permitido do campo
	.T.,;                                                                                       // [10]  L   Indica se o campo tem preenchimento obrigatµrio
	FwBuildFeature( STRUCT_FEATURE_INIPAD, "Iif(!INCLUI,"+oFncComp:cAliasTmp+"->TABBREV,'')" ),;      // [11]  B   Code-block de inicializacao do campo
	.F.,;                                                                                       // [12]  L   Indica se trata-se de um campo chave
	.F.,;                                                                                       // [13]  L   Indica se o campo pode receber valor em uma operaÓÐo de update.
	.F.)                                                                                        // [14]  L   Indica se o campo Õ virtual

	oStTmp:AddField(;
		"NomeEmpresa",;                                                                                  // [01]  C   Titulo do campo
	"NomeEmpresa",;                                                                                  // [02]  C   ToolTip do campo
	"TM0NOMECOM",;                                                                              // [03]  C   Id do Field
	"C",;                                                                                       // [04]  C   Tipo do campo
	060,;                                                                                        // [05]  N   Tamanho do campo
	00,;                                                                                        // [06]  N   Decimal do campo
	Nil,;                                                                                       // [07]  B   Code-block de validaÓÐo do campo
	Nil,;                                                                                       // [08]  B   Code-block de validaÓÐo When do campo
	{},;                                                                                        // [09]  A   Lista de valores permitido do campo
	.F.,;                                                                                       // [10]  L   Indica se o campo tem preenchimento obrigatµrio
	FwBuildFeature( STRUCT_FEATURE_INIPAD, "Iif(!INCLUI,"+oFncComp:cAliasTmp+"->TM0NOMECOM,'')" ),;      // [11]  B   Code-block de inicializacao do campo
	.F.,;                                                                                       // [12]  L   Indica se trata-se de um campo chave
	.F.,;                                                                                       // [13]  L   Indica se o campo pode receber valor em uma operaÓÐo de update.
	.F.)                                                                                        // [14]  L   Indica se o campo Õ virtual

	oStTmp:AddField(;
		"CGC",;                                                                             // [01]  C   Titulo do campo
	"CGC",;                                                                             // [02]  C   ToolTip do campo
	"TM0_CGC",;                                                                              // [03]  C   Id do Field
	"C",;                                                                                       // [04]  C   Tipo do campo
	014,;                                                                                        // [05]  N   Tamanho do campo
	00,;                                                                                        // [06]  N   Decimal do campo
	Nil,;                                                                                       // [07]  B   Code-block de validaÓÐo do campo
	Nil,;                                                                                       // [08]  B   Code-block de validaÓÐo When do campo
	{},;                                                                                        // [09]  A   Lista de valores permitido do campo
	.F.,;                                                                                       // [10]  L   Indica se o campo tem preenchimento obrigatµrio
	FwBuildFeature( STRUCT_FEATURE_INIPAD, "Iif(!INCLUI,"+oFncComp:cAliasTmp+"->TM0_CGC,'')" ),;      // [11]  B   Code-block de inicializacao do campo
	.F.,;                                                                                       // [12]  L   Indica se trata-se de um campo chave
	.F.,;                                                                                       // [13]  L   Indica se o campo pode receber valor em uma operaÓÐo de update.
	.F.)                                                                                        // [14]  L   Indica se o campo Õ virtual

	oStTmp:AddField(;
		"ATIVO",;                                                                                    // [01]  C   Titulo do campo
	"ATIVO",;                                                                                    // [02]  C   ToolTip do campo
	"TACTIVE",;                                                                                  // [03]  C   Id do Field
	"C",;                                                                                       // [04]  C   Tipo do campo
	001,;                                                                                        // [05]  N   Tamanho do campo
	00,;                                                                                        // [06]  N   Decimal do campo
	Nil,;                                                                                       // [07]  B   Code-block de validaÓÐo do campo
	Nil,;                                                                                       // [08]  B   Code-block de validaÓÐo When do campo
	{"Y=Yes", "N=No"},;                               							                 // [09] A   Lista de valores permitido do campo
	.F.,;                                                                                       // [10]  L   Indica se o campo tem preenchimento obrigatµrio
	FwBuildFeature( STRUCT_FEATURE_INIPAD, "Iif(!INCLUI,"+oFncComp:cAliasTmp+"->TACTIVE,'Y')" ),; // [11]  B   Code-block de inicializacao do campo
	.F.,;                                                                                       // [12]  L   Indica se trata-se de um campo chave
	.F.,;                                                                                       // [13]  L   Indica se o campo pode receber valor em uma operaÓÐo de update.
	.F.)                                                                                        // [14]  L   Indica se o campo Õ virtual


	//Instanciando o modelo
	oModel := MPFormModel():New("FuncCompM",/*bPre*/, /*bPos*/,/*bCommit*/,/*bCancel*/)
	oModel:AddFields("FORMTMP",/*cOwner*/,oStTMP)
	oModel:SetPrimaryKey({'TCFUNCTION','TCOMPANY'})
	oModel:SetDescription("Modelo de Dados do Cadastro "+oFncComp:cTitulo)
	oModel:GetModel("FORMTMP"):SetDescription("FormulÃrio do Cadastro "+oFncComp:cTitulo)

	//Instala um evento no modelo de dados que irÃ ficar "observando" as alteraÓ¾es do formulÃrio
	oModel:InstallEvent("VLD_TMPTAB", , oFncComp)
Return oModel

/*/{Protheus.doc} ViewDef
Define a **Interface Visual (View)** da rotina. Ela determina como os campos serÐo exibidos (ex: ComboBox para o campo ATIVO), 
organiza o layout da tela em boxes horizontais e associa a interface ao modelo de dados.
@type function
@author eduardo.brust
@since 1/21/2026
@return object, Objeto do tipo FwFormView
/*/
User function ViewDef() as object
	Local oModel := FWLoadModel("MvcFunctionCompany.FuncComp")
	Local oStTMP := FWFormViewStruct():New()
	Local oView := Nil

	//Adiciona os campos da estrutura
	oStTmp:AddField("TCFUNCTION","01","Rotina","Rotina",,'Get',Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,.T.)
	oStTmp:AddField("TCOMPANY","02","Empresa","Empresa",,'Get',Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,.T.)
	oStTmp:AddField("TABBREV","03","Sigla","Sigla",,'Get',Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,.T.)
	oStTmp:AddField("TM0NOMECOM","04","NomeEmpresa","NomeEmpresa",,'Get',Nil,Nil,Nil,.F.,Nil,Nil,Nil,Nil,Nil,.T.)
	oStTmp:AddField("TM0_CGC","05","CGC","CGC",,'Get',Nil,Nil,Nil,.F.,Nil,Nil,Nil,Nil,Nil,.T.)
	oStTmp:AddField("TACTIVE","06","ATIVO","ATIVO",,'Get',Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,Nil,.T.)

	//definindo algumas propriedades nos campos
	oStTmp:SetProperty("TCFUNCTION", MVC_VIEW_PICT, "@!")
	oStTmp:SetProperty("TCOMPANY", MVC_VIEW_PICT, "999999")
	oStTmp:SetProperty("TABBREV", MVC_VIEW_PICT, "@!")
	oStTmp:SetProperty("TACTIVE", MVC_VIEW_COMBOBOX, {"Y=Yes", "N=No"})

	//Criando a view que serÃ o retorno da funÓÐo e setando o modelo da rotina
	oView := FWFormView():New()
	oView:SetModel(oModel)
	oView:AddField("VIEW_TMP", oStTMP, "FORMTMP")
	oView:CreateHorizontalBox("TELA",100)
	oView:EnableTitleView('VIEW_TMP', 'Dados - '+oFncComp:cTitulo )
	oView:SetCloseOnOk({||.T.})
	oView:SetOwnerView("VIEW_TMP","TELA")
Return oView

/*/{Protheus.doc} MenuDef
Retorna um array com as **opÓ¾es de menu** disponÚveis na rotina. Define quais operaÓ¾es o usuÃrio pode realizar, 
como Pesquisar, Visualizar, Incluir, Alterar, Excluir, Imprimir e Copiar.
@type function
@author eduardo.brust
@since 1/21/2026
@return array, Array contendo as opÓ¾es da rotina, algumas opÓ¾es
nÐo sÐo apresentadas diretamente como bot¾es, Õ necessÃrio ir nas
outras aÓ¾es
/*/
User function MenuDef() as array
	local aRotina := {} as array

	Add Option aRotina Title "Pesquisar" Action "PesqBrw" Operation OP_PESQUISAR Access 0
	Add Option aRotina Title "Visualizar" Action "ViewDef.MvcFunctionCompany.FuncComp" Operation OP_VISUALIZAR Access 0
	Add Option aRotina Title "Incluir" Action "ViewDef.MvcFunctionCompany.FuncComp" Operation OP_INCLUIR Access 0
	Add Option aRotina Title "Alterar" Action "ViewDef.MvcFunctionCompany.FuncComp" Operation OP_ALTERAR Access 0
	Add Option aRotina Title "Excluir" Action "ViewDef.MvcFunctionCompany.FuncComp" Operation OP_EXCLUIR Access 0
	Add Option aRotina Title "Imprimir" Action "ViewDef.MvcFunctionCompany.FuncComp" Operation OP_IMPRIMIR Access 0
	Add Option aRotina Title "Copiar" Action "ViewDef.MvcFunctionCompany.FuncComp" Operation OP_COPIA Access 0

return aRotina
